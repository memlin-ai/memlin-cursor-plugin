{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/dist/hooks/session-start.js\"",
        "timeout": 10
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/dist/hooks/before-submit-prompt.js\"",
        "timeout": 10
      }
    ],
    "preToolUse": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/dist/hooks/pre-tool-use.js\"",
        "timeout": 5
      }
    ],
    "afterFileEdit": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/dist/hooks/after-file-edit.js\"",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/dist/hooks/stop.js\"",
        "timeout": 15
      }
    ]
  }
}
